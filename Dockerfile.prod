# syntax=docker/dockerfile:1
# =============================================================================
# Stage 1: Builder - Build the application
# =============================================================================
FROM node:22-slim AS builder

WORKDIR /app/taskosaur

# Configure npm for better network reliability (env vars inherited by all child processes)
ENV npm_config_fetch_timeout=150000 \
    npm_config_fetch_retries=5 \
    npm_config_fetch_retry_mintimeout=20000 \
    npm_config_fetch_retry_maxtimeout=150000

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    git \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Set dummy DATABASE_URL for Prisma generate (required during build)
ENV DATABASE_URL="postgresql://dummy:dummy@localhost:5432/dummy?schema=public"

# ------- Layer cache: install dependencies first, source code later -------

# Copy only package files and scripts (changes rarely → cached layer)
COPY package.json package-lock.json ./
COPY backend/package.json backend/package.dist.json ./backend/
COPY frontend/package.json ./frontend/
COPY scripts ./scripts

# Install dependencies with BuildKit cache mount for npm cache
RUN --mount=type=cache,target=/root/.npm \
    npm install

# ------- Now copy source code (changes frequently → invalidates from here) -------

COPY backend ./backend
COPY frontend ./frontend

# Accept build number as build argument (placed AFTER npm install so it doesn't bust dep cache)
ARG BUILD_NUMBER
ENV BUILD_NUMBER=${BUILD_NUMBER}

# Build the distribution
RUN npm run build:dist

# =============================================================================
# Stage 2: Production - Minimal runtime image
# =============================================================================
FROM node:22-slim AS production

WORKDIR /app/taskosaur

# Install only runtime dependencies and netcat for health checks
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    netcat-openbsd \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Copy entrypoint script (before switching to www-data)
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Change ownership of /app to www-data
RUN chown -R www-data:www-data /app

# Switch to www-data user
USER www-data

# Configure npm to use a writable cache directory for www-data user
ENV NPM_CONFIG_CACHE=/tmp/.npm
ENV NPM_CONFIG_PREFIX=/tmp/.npm-global

# Copy only the dist directory from builder stage
COPY --chown=www-data:www-data --from=builder /app/taskosaur/dist .

# Validate that required files exist in the dist folder
RUN if [ ! -f "package.json" ]; then \
        echo "ERROR: dist directory is missing required files (package.json not found)"; \
        exit 1; \
    fi

# Expose the application port
EXPOSE 3000

# Set the entrypoint
ENTRYPOINT ["/entrypoint.sh"]

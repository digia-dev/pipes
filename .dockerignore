# Node modules (must be excluded to prevent architecture conflicts)
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Development files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.test

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentation
*.md
LICENSE*
CODE_OF_CONDUCT*
CONTRIBUTING*
SECURITY*

# Build outputs
dist/
build/
.next/
out/

# Test files
test/
tests/
**/*.test.js
**/*.spec.js
**/*.test.ts
**/*.spec.ts
coverage/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Socket files
*.sock

# Docker files (except entrypoint)
Dockerfile*
docker-compose*
.dockerignore

# Development-only tools
.eslintrc*
.prettierrc*
jest.config.*

# Uploads and data
uploads/
docker-data/

# Scripts (not needed in build)
sync_to_oss.sh
